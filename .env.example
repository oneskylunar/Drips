# ╔═══════════════════════════════════════════════════════════════════╗
# ║  DRIPS — ENVIRONMENT CONFIGURATION TEMPLATE                  ║
# ║  Copy this file to .env and fill in your values.                ║
# ║  Variables marked (optional) can be left empty/commented out.   ║
# ╚═══════════════════════════════════════════════════════════════════╝

# --- Bot Identity ---
BOT_NAME=Drips
BOT_PREFIX=^[.!/]
# Include country code
OWNER_NUMBERS=123456789012,123456789023

# --- WhatsApp Connection ---
# Leave PAIRING_NUMBER empty for QR code mode
PAIRING_NUMBER=
# Custom pairing code (8 characters, letters/numbers). Leave empty for auto-generated code.
PAIRING_CODE=
SESSION_DIR=auth_info
SESSION_NAME=drips_session
MAX_RECONNECT_ATTEMPTS=6
RECONNECT_INTERVAL_MS=2000

# --- Anti-Detection / Human Mimicry ---
TYPING_CHAR_DELAY_MS=100
GAUSSIAN_DELAY_MIN_MS=250
GAUSSIAN_DELAY_MAX_MS=2000
READ_RECEIPT_DELAY_MS=1500

# --- Queue ---
QUEUE_CONCURRENCY=3
QUEUE_JOB_TTL_MS=60000
QUEUE_EMOJI=⏳

# --- Redis (optional - omit REDIS_HOST to use in-memory store) ---
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=drips:

# --- Hot Reload ---
PLUGIN_DIR=src/plugins
MIDDLEWARE_DIR=src/middleware
HOT_RELOAD_DEBOUNCE_MS=500

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=

# --- Feature Flags ---
ENABLE_READ_RECEIPTS=true
ENABLE_PRESENCE=true
ENABLE_ANTI_DETECTION=true
